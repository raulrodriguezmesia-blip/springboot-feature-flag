{
  "dashboard": {
    "id": null,
    "title": "Resilience Historical Dashboard",
    "tags": ["spring-boot", "feature-flag", "resilience", "historical", "multi-cloud"],
    "timezone": "browser",
    "schemaVersion": 36,
    "version": 1,
    "refresh": "30s",
    "templating": {
      "list": [
        {
          "name": "timeRange",
          "type": "custom",
          "label": "Time Range",
          "query": "7d,30d,90d",
          "default": "7d",
          "description": "Select time range for historical view"
        }
      ]
    },
    "panels": [
      {
        "id": 1,
        "type": "timeseries",
        "title": "Availability History (Uptime %)",
        "gridPos": {"h": 6, "w": 12, "x": 0, "y": 0},
        "datasource": "Prometheus",
        "fieldConfig": {
          "defaults": {
            "unit": "percent",
            "min": 0,
            "max": 100,
            "thresholds": {
              "mode": "absolute",
              "steps": [
                {"color": "red", "value": null},
                {"color": "yellow", "value": 95},
                {"color": "green", "value": 99}
              ]
            }
          }
        },
        "targets": [
          {
            "expr": "probe_success{job=\"springboot-feature-flag\"} * 100",
            "legendFormat": "Availability %"
          }
        ]
      },
      {
        "id": 2,
        "type": "stat",
        "title": "Average Failover Time (seconds)",
        "gridPos": {"h": 3, "w": 6, "x": 12, "y": 0},
        "datasource": "Prometheus",
        "fieldConfig": {
          "defaults": {
            "unit": "s",
            "thresholds": {
              "mode": "absolute",
              "steps": [
                {"color": "green", "value": null},
                {"color": "yellow", "value": 60},
                {"color": "red", "value": 120}
              ]
            }
          }
        },
        "options": {"colorMode": "value", "reduceOptions": {"calcs": ["mean"]}},
        "targets": [
          {
            "expr": "failover_duration_seconds",
            "format": "table",
            "instant": true
          }
        ]
      },
      {
        "id": 3,
        "type": "table",
        "title": "Failover Events Timeline",
        "gridPos": {"h": 3, "w": 6, "x": 12, "y": 3},
        "datasource": "Loki",
        "options": {"showHeader": true},
        "targets": [
          {
            "expr": "{app=\"springboot-feature-flag\"} |= \"failover\"",
            "refId": "A"
          }
        ]
      },
      {
        "id": 4,
        "type": "table",
        "title": "Historical Chaos Tests",
        "gridPos": {"h": 8, "w": 12, "x": 0, "y": 6},
        "datasource": "Loki",
        "options": {"showHeader": true},
        "targets": [
          {
            "expr": "{app=\"springboot-feature-flag\"} |= \"Chaos experiment\"",
            "refId": "A"
          }
        ],
        "fieldConfig": {
          "defaults": {
            "custom": {},
            "mappings": [
              {"type": 1, "options": {"match": {"id": 0, "value": "passed"}, "result": {"text": "Passed", "color": "green"}}
            ]
          }
        }
      },
      {
        "id": 5,
        "type": "piechart",
        "title": "Resilience Rate by Test Cycle",
        "gridPos": {"h": 4, "w": 6, "x": 12, "y": 6},
        "datasource": "Prometheus",
        "targets": [
          {
            "expr": "chaos_experiment_passed_total{job=\"springboot-feature-flag\"}",
            "refId": "A"
          }
        ]
      },
      {
        "id": 6,
        "type": "timeseries",
        "title": "Historical Latency (ms)",
        "gridPos": {"h": 5, "w": 12, "x": 0, "y": 14},
        "datasource": "Prometheus",
        "fieldConfig": {
          "defaults": {
            "unit": "ms",
            "thresholds": {
              "mode": "absolute",
              "steps": [
                {"color": "green", "value": null},
                {"color": "yellow", "value": 200},
                {"color": "red", "value": 500}
              ]
            }
          }
        },
        "targets": [
          {
            "expr": "rate(http_server_requests_seconds_sum{job=\"springboot-feature-flag\",uri!~\"/actuator.*\"}[5m]) / rate(http_server_requests_seconds_count{job=\"springboot-feature-flag\",uri!~\"/actuator.*\"}[5m]) * 1000",
            "legendFormat": "Latency (ms)"
          }
        ]
      },
      {
        "id": 7,
        "type": "table",
        "title": "Historical Alerts",
        "gridPos": {"h": 6, "w": 12, "x": 0, "y": 19},
        "datasource": "Loki",
        "targets": [
          {
            "expr": "{app=\"springboot-feature-flag\"} |= \"ALERT\" or \"alert\"",
            "refId": "A"
          }
        ],
        "fieldConfig": {
          "defaults": {
            "custom": {},
            "mappings": [
              {"type": 1, "options": {"match": {"id": 0, "value": "critical"}, "result": {"text": "Critical", "color": "red"}}
            ]
          }
        }
      }
    ]
  }
}
